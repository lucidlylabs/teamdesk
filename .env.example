# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/teamdesk?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Discord incoming webhooks (create in Server Settings > Integrations > Webhooks)
DISCORD_DAILY_SUMMARY_WEBHOOK=""
DISCORD_RESEARCH_WEBHOOK=""

# Secret to protect the /api/cron/* endpoints (use as Bearer token)
CRON_SECRET="change-me"

# DeepSeek (LLM-powered daily summary). If empty, falls back to the template.
DEEPSEEK_API_KEY=""

# Sentry error tracking (optional). If empty, Sentry is disabled at build + runtime.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Only needed if you want sourcemap uploads on build:
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

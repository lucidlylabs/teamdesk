generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  TEAM
  USER
  ADMIN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum PipelineStatus {
  PLANNED
  ACTIVE
  BLOCKED
  SHIPPED
}

enum FocusStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE_PERFECT
}

model Whitelist {
  id        String   @id @default(cuid())
  email     String   @unique
  note      String?
  createdAt DateTime @default(now())
}

model User {
  id          String        @id @default(cuid())
  email       String        @unique
  name        String
  password    String
  role        Role          @default(USER)
  createdAt   DateTime      @default(now())
  attendance  Attendance[]
}

model Attendance {
  id           String           @id @default(cuid())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  date         DateTime         @db.Date
  status       AttendanceStatus @default(PRESENT)
  currentTask  String?
  workingRepo  String?
  taskStatus   String?
  blockers     String?
  createdAt    DateTime         @default(now())
  @@unique([userId, date])
  @@index([date])
}

model Pipeline {
  id           String         @id @default(cuid())
  title        String
  workingRepo  String?
  summary      String
  totalTasks   Int            @default(0)
  doneTasks    Int            @default(0)
  status       PipelineStatus @default(ACTIVE)
  updatedAt    DateTime       @updatedAt
  createdAt    DateTime       @default(now())
}

model Research {
  id        String   @id @default(cuid())
  title     String
  url       String
  notes     String?
  postedBy  String?
  createdAt DateTime @default(now())
}

model DailySummary {
  id        String   @id @default(cuid())
  date      DateTime @db.Date @unique
  summary   String
  refs      String?
  createdAt DateTime @default(now())
}

// THE 3 — shared daily company focus. One DailyFocus per day, max 3 FocusItems.
model FocusSettings {
  id        String   @id // app always uses the literal "singleton"
  northStar String?
  weekGoal  String?
  updatedAt DateTime @updatedAt
}

model DailyFocus {
  id        String      @id @default(cuid())
  date      DateTime    @db.Date @unique
  recap     String?
  items     FocusItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  @@index([date])
}

model FocusItem {
  id          String      @id @default(cuid())
  focus       DailyFocus  @relation(fields: [focusId], references: [id], onDelete: Cascade)
  focusId     String
  rank        Int
  title       String
  owner       String?
  revenueWhy  String
  perfectWhen String
  status      FocusStatus @default(NOT_STARTED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  @@unique([focusId, rank])
}
